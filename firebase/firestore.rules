rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return isSignedIn() && userDoc().exists;
    }

    function userBusinessId() {
      return userExists() ? userDoc().data.get('businessId', '') : '';
    }

    function userRole() {
      return userDoc().data.role;
    }

    function isBootstrapSuperadminEmail() {
      return request.auth.token.email != null
        && request.auth.token.email.lower() == 'kreshnik.sh.gashi@hotmail.com';
    }

    function isSuperAdmin() {
      return userExists() && userRole() == 'superadmin';
    }

    /// Firestore role or bootstrap email (app may route to superadmin before profile sync).
    function isPlatformAdmin() {
      return isBootstrapSuperadminEmail() || isSuperAdmin();
    }

    function canBootstrapPromoteToSuperadmin(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && isBootstrapSuperadminEmail()
        && request.resource.data.role == 'superadmin'
        && request.resource.data.email.lower() == 'kreshnik.sh.gashi@hotmail.com'
        && request.resource.data.maxBusinesses == 100
        && request.resource.data.businessId == ''
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['role', 'maxBusinesses', 'businessId']);
    }

    function businessDoc(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId));
    }

    function businessExists(businessId) {
      return exists(/databases/$(database)/documents/businesses/$(businessId));
    }

    function isBusinessOwner(businessId) {
      return isSignedIn()
        && businessExists(businessId)
        && businessDoc(businessId).data.ownerId == request.auth.uid;
    }

    function ownsBusiness(businessId) {
      return isBusinessOwner(businessId);
    }

    function isMember(businessId) {
      return isPlatformAdmin()
        || isBusinessOwner(businessId)
        || (isSignedIn() && userBusinessId() == businessId);
    }

    function hasStaffWriteRole(businessId) {
      return isPlatformAdmin()
        || (userExists()
            && userBusinessId() == businessId
            && userRole() in ['owner', 'admin', 'manager']);
    }

    function canRead(businessId) {
      return isMember(businessId);
    }

    function canWrite(businessId) {
      return isPlatformAdmin() || isBusinessOwner(businessId) || hasStaffWriteRole(businessId);
    }

    function canManageUsers(businessId) {
      return isPlatformAdmin()
        || isBusinessOwner(businessId)
        || (userExists()
            && userBusinessId() == businessId
            && userRole() in ['owner', 'admin']);
    }

    function canManageApiKeys(businessId) {
      return canManageUsers(businessId);
    }

    match /users/{userId} {
      allow read: if isPlatformAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['businessId', 'role', 'email'])
        && (
          request.resource.data.role in ['owner', 'admin']
          || (request.resource.data.role == 'superadmin'
              && request.resource.data.email == 'kreshnik.sh.gashi@hotmail.com')
        );
      allow update: if isPlatformAdmin()
        || canBootstrapPromoteToSuperadmin(userId)
        || (isSignedIn()
            && request.auth.uid == userId
            && request.resource.data.role == resource.data.role
            && (
              request.resource.data.businessId == resource.data.businessId
              || ownsBusiness(request.resource.data.businessId)
            ));
      allow delete: if isPlatformAdmin();

      match /notifications/{notificationId} {
        allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && (
          request.auth.uid == userId
          || (isPlatformAdmin()
              && request.resource.data.type.matches('platform\\..*'))
        );
      }

      match /invoices/{invoiceId} {
        allow read: if isPlatformAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow create: if isPlatformAdmin()
          || (isSignedIn()
              && request.auth.uid == userId
              && request.resource.data.userId == userId);
        allow update, delete: if isPlatformAdmin();
      }
    }

    match /invoice_counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /billing_reports/{reportId} {
      allow read: if isPlatformAdmin();
      allow create, update: if isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    match /businesses/{businessId} {
      allow read: if isPlatformAdmin()
        || (isSignedIn() && (
          resource.data.ownerId == request.auth.uid
          || (userExists() && userBusinessId() == businessId)
        ));
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isPlatformAdmin()
        || canManageUsers(businessId)
        || (canWrite(businessId)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId']));
      allow delete: if isPlatformAdmin() || isBusinessOwner(businessId);

      match /categories/{docId} {
        allow read: if canRead(businessId);
        allow create, update, delete: if canWrite(businessId);
      }

      match /products/{docId} {
        allow read: if canRead(businessId);
        allow create, update, delete: if canWrite(businessId);
      }

      match /offers/{docId} {
        allow read: if canRead(businessId);
        allow create, update, delete: if canWrite(businessId);
      }

      match /productVariants/{docId} {
        allow read: if canRead(businessId);
        allow create, update, delete: if canWrite(businessId);
      }

      match /attributes/{docId} {
        allow read: if canRead(businessId);
        allow create, update, delete: if canWrite(businessId);
      }

      match /attributeValues/{docId} {
        allow read: if canRead(businessId);
        allow create, update, delete: if canWrite(businessId);
      }

      match /media/{docId} {
        allow read: if canRead(businessId);
        allow create, update, delete: if canWrite(businessId);
      }

      match /apiKeys/{docId} {
        allow read: if canManageApiKeys(businessId);
        allow create, update, delete: if canManageApiKeys(businessId);
      }

      match /settings/{docId} {
        allow read: if canRead(businessId);
        allow create, update, delete: if canManageUsers(businessId);
      }

      match /orders/{orderId} {
        allow read: if canRead(businessId);
        allow update: if canWrite(businessId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt', 'cancelledAt', 'confirmedAt', 'cancelledBy']);
        allow create, delete: if false;
      }
    }

    match /slugs/{slugId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isPlatformAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow update: if false;
    }

    // collectionGroup('products') queries (superadmin products tab)
    match /{path=**}/products/{productId} {
      allow read, delete: if isPlatformAdmin();
    }

    // collectionGroup('invoices') — superadmin billing / reports
    match /{path=**}/invoices/{invoiceId} {
      allow read: if isPlatformAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isPlatformAdmin()
        || (isSignedIn()
            && request.auth.uid == request.resource.data.userId);
      allow update, delete: if isPlatformAdmin();
    }

    match /social_posts/{docId} {
      allow read, write: if false;
    }
  }
}
